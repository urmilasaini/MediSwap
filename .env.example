# ── Copy to .env and edit ─────────────────────────────────────────────────────

APP_NAME=PharmaAI
APP_VERSION=1.0.0
APP_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Paths are relative to project root
DB_PATH=data/medicines.db
DATA_CSV=data/medicines.csv

# ── Qdrant vector store ───────────────────────────────────────────────────────
# QDRANT_MODE options:
#   memory  → in-process (rebuilt every restart, good for dev/HF Spaces)
#   local   → file-backed (persists at QDRANT_PATH)
#   remote  → connects to running Qdrant at QDRANT_URL
QDRANT_MODE=local
QDRANT_PATH=data/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=medicines

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── Tuning ────────────────────────────────────────────────────────────────────
FUZZY_THRESHOLD=65
FUZZY_LIMIT=10
SEMANTIC_LIMIT=6
ALTERNATIVES_LIMIT=10
